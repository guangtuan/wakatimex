APP_NAME=wakatime-sync
APP_ENV=dev
APP_PORT=9506
APP_TIMEZONE=UTC

MYSQL_DSN=mysql://root:123456@localhost:3306/wakatime_sync
WAKATIME_API_BASE=https://api.wakatime.com/api/v1
# Optional if already in ~/.wakatime.cfg
WAKATIME_API_KEY=

SYNC_HOUR_UTC=2
